# ------------------------------------------------------------------
# RetroWiki — configuração de ambiente
# Copie para .env e preencha. Nunca commite o .env.
# ------------------------------------------------------------------

NODE_ENV=development

# URL pública do app (usada em e-mails e links absolutos).
# Deploy recomendado: um subdomínio, ex.: https://retro.wiki.br
APP_URL=http://localhost:3000

# Deploy opcional em subdiretório (ex.: https://site.com/wiki/). Vazio = subdomínio.
# BASE_PATH=/wiki

# String de conexão MySQL. No Docker Compose o host é o nome do serviço (mysql).
DATABASE_URL=mysql://retrowiki:retrowiki@127.0.0.1:3306/retrowiki

# Segredo do Auth.js. Gere com: openssl rand -base64 33
AUTH_SECRET=mude-para-uma-string-longa-e-aleatoria

# Segredo do captcha proprietário (RetroGuard). Gere com: openssl rand -base64 33
CAPTCHA_SECRET=mude-para-outra-string-longa-e-aleatoria

# Diretório de armazenamento (imagens de device, uploads). No Docker é um volume.
STORAGE_DIR=./storage

# Token do GitHub (opcional) para elevar o rate limit da API de releases (60→5000/h).
GITHUB_TOKEN=

# Segredo para proteger os endpoints de cron (ex.: sync de releases). Gere com:
# openssl rand -base64 33. Envie como header Authorization: Bearer <valor>.
CRON_SECRET=

# E-mail transacional (Resend). Deixe RESEND_API_KEY vazio em dev para
# registrar os e-mails no console em vez de enviá-los.
RESEND_API_KEY=
EMAIL_FROM=RetroWiki <nao-responda@localhost>

# Conta admin inicial, criada por `npm run db:seed` (e pelo seed do container).
SEED_ADMIN_EMAIL=admin@retrowiki.local
SEED_ADMIN_PASSWORD=mude-por-favor

# ------------------------------------------------------------------
# Apenas Docker Compose (não lido diretamente pelo app)
# ------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=retrowiki
MYSQL_USER=retrowiki
MYSQL_PASSWORD=retrowiki
MYSQL_HOST_PORT=3306

# ===================================================================
# BUNNY
# ===================================================================
BUNNY_STORAGE_KEY=db67c3ad-805b-44de-ba5421bc836e-8080-4c52
BUNNY_STORAGE_KEY_READONLY=94c1b3af-6a08-4f7e-996b01951d9a-6f56-4a4d
BUNNY_STORAGE_REGION=br
BUNNY_PULL_ZONE=retrowiki
BUNNY_CDN_TOKEN=2b5742bf-34f4-446d-a9ef-52d130ac80f6
BUNNY_CDN_URL=https://retrowiki.b-cdn.net